APP_NAME="SMK ABC Library"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://smk-abc-library.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Herd's bundled MySQL listens on localhost:3306 with root/empty-password by default.
# If you've changed Herd's MySQL credentials, update these to match.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smk_abc_library
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=720
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

# Library circulation rules \u2014 tune these to your school's actual policy
LIBRARY_LOAN_DAYS=14
LIBRARY_FINE_CENTS_PER_DAY=25
LIBRARY_MAX_CHECKOUTS_PER_STUDENT=5
